{
  "name": "do-eat-borne",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "build:web": "cd ../born_dz && npx expo export -p web",
    "dist": "npm run build:web && electron-builder"
  },
  "build": {
    "appId": "com.doeat.borne",
    "productName": "MenuGo Borne",
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../born_dz/dist",
        "to": "web-build",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "escpos-serialport": "^3.0.0-alpha.4",
    "express": "^4.22.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^32.2.7",
    "electron-builder": "^24.13.3"
  }
}